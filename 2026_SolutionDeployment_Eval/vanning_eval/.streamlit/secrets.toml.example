# このファイルをコピーして `.streamlit/secrets.toml` にリネームし、
# 各自で発行した PAT を埋めてください。secrets.toml は .gitignore 済みで共有されません。
# PAT 取得手順は README の「GitHub PAT の取得」セクションを参照。

# GitHub Fine-grained PAT（Contents: Read and write）
GITHUB_TOKEN = "github_pat_xxx"

# 書き込み対象リポジトリ
GITHUB_OWNER = "ornamentsclimate"
GITHUB_REPO = "2026_SolutionDeployment_Eval"

# リポジトリ内の履歴ファイルパス
SCOREBOARD_PATH = "scoreboard/history.json"

# 書き込み先ブランチ
SCOREBOARD_BRANCH = "main"

# 投稿フォームの「投稿者」欄の既定値（任意）
DEFAULT_AUTHOR = "your-name"
